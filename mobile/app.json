{
  "expo": {
    "name": "Stack",
    "slug": "stack",
    "scheme": "stack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0A0A0B",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "online.stackapp.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Stack uses your camera so you can take your daily check-in photo.",
        "NSPhotoLibraryUsageDescription": "Stack lets you choose a check-in photo from your library when no camera is available.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "online.stackapp.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0B"
      },
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "POST_NOTIFICATIONS"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 160,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0B"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Stack lets you choose a check-in photo from your library.",
          "cameraPermission": "Stack uses your camera so you can take your daily check-in photo."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C6F806"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": { "deploymentTarget": "16.4" },
          "android": { "compileSdkVersion": 35, "targetSdkVersion": 35 }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "owner": "REPLACE_WITH_EXPO_USERNAME"
  }
}
