# Copy to mobile/.env and fill in from your Supabase project (Settings → API).
# These are the SAME values the web app uses — the native app shares the backend.
# EXPO_PUBLIC_* vars are inlined into the app bundle at build time.

EXPO_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-or-publishable-key>

# Canonical web origin (share links / deep links). Optional.
EXPO_PUBLIC_SITE_URL=https://www.stack-app.online
